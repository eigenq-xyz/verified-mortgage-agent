# LLM provider configuration — use "provider/model-name" format (LangChain init_chat_model)
# Examples:
#   anthropic/claude-sonnet-4-6
#   openai/gpt-4o
#   google-genai/gemini-2.0-flash
LLM_MODEL=anthropic/claude-sonnet-4-6

# Per-agent model overrides (optional — falls back to LLM_MODEL)
# LLM_MODEL_INTAKE=anthropic/claude-haiku-4-5-20251001
# LLM_MODEL_RISK=anthropic/claude-sonnet-4-6
# LLM_MODEL_COMPLIANCE=anthropic/claude-sonnet-4-6
# LLM_MODEL_UNDERWRITER=anthropic/claude-sonnet-4-6
# LLM_MODEL_ROUTER=anthropic/claude-haiku-4-5-20251001

# Provider API keys — set whichever provider(s) you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Lean binary path (leave blank to use PATH)
LEAN_BINARY_PATH=

# Set to 1 to run integration tests (requires live LLM + Lean binary)
ENABLE_INTEGRATION_TESTS=0
